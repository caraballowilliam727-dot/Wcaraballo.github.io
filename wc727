    border-bottom: 1px solid #1a1a1a;
}

.container {
    max-width: 1100px;
    margin: auto;
}

.grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
}

.card {
    background: #111;
    padding: 25px;
    border-radius: 10px;
    transition: 0.3s;
}

.card:hover {
    transform: translateY(-6px);
}

.fade {
    opacity: 0;
    transform: translateY(20px);
    transition: 0.6s ease;
}

.fade.show {
    opacity: 1;
    transform: translateY(0);
}

button {
    padding: 14px 22px;
    background: #fff;
    color: #000;
    border: none;
    cursor: pointer;
    font-weight: bold;
    border-radius: 6px;
}

footer {
